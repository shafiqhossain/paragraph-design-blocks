{#
/**
* @file
* Default theme implementation to display a paragraph.
*
* Available variables:
* - paragraph: Full paragraph entity.
* Only method names starting with "get", "has", or "is" and a few common
* methods such as "id", "label", and "bundle" are available. For example:
* - paragraph.getCreatedTime() will return the paragraph creation timestamp.
* - paragraph.id(): The paragraph ID.
* - paragraph.bundle(): The type of the paragraph, for example, "image" or "text".
* - paragraph.getOwnerId(): The user ID of the paragraph author.
* See Drupal\paragraphs\Entity\Paragraph for a full list of public properties
* and methods for the paragraph object.
* - content: All paragraph items. Use {{ content }} to print them all,
* or print a subset such as {{ content.field_example }}. Use
* {{ content|without('field_example') }} to temporarily suppress the printing
* of a given child element.
* - attributes: HTML attributes for the containing element.
* The attributes.class element may contain one or more of the following
* classes:
* - paragraphs: The current template type (also known as a "theming hook").
* - paragraphs--type-[type]: The current paragraphs type. For example, if the paragraph is an
* "Image" it would result in "paragraphs--type--image". Note that the machine
* name will often be in a short form of the human readable label.
* - paragraphs--view-mode--[view_mode]: The View Mode of the paragraph; for example, a
* preview would result in: "paragraphs--view-mode--preview", and
* default: "paragraphs--view-mode--default".
* - view_mode: View mode; for example, "preview" or "full".
* - logged_in: Flag for authenticated user status. Will be true when the
* current user is a logged-in member.
* - is_admin: Flag for admin user status. Will be true when the current user
* is an administrator.
*
* @see template_preprocess_paragraph()
*
* @ingroup themeable
*/
#}
{%
  set classes = [
    'paragraph',
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
    not paragraph.isPublished() ? 'paragraph--unpublished',
    paragraph.field_accordion_color_bg.value == 'blue' ? 'accordion-style-blue' : 'accordion-style-white'
  ]
%}

{# anchor start #}
{% if paragraph.field_anchor_position is empty %}
  {% set anchor_pos = 1 %}
{% else %}
  {% set anchor_pos = paragraph.field_anchor_position %}
{% endif %}
{# anchor end #}

{% block paragraph %}
  <div{{ attributes.addClass(classes) }} data-type-anchor="anchor-position--accordion-section-{{ anchor_pos }}">
    <div id="anchor-position--accordion-section-{{ anchor_pos }}"></div>
    <div class="container clearfix">
      {% if paragraph.field_accordion_section_title.value is not empty %}
        <h3 class="accordion-section-headline">{{ paragraph.field_accordion_section_title.value }}</h3>
      {% endif %}
      {% if paragraph.field_accordion_section_title.value is not empty %}
        <h5 class="accordion-section-subtitle">{{ paragraph.field_accordion_section_subtitle.value }}</h5>
      {% endif %}

      {# Full width - one column start #}
      {% if paragraph.field_accordion_section_layout.value == 1 %}
        <div class="accordion accordion-items-list" id="accordion-item-accordion-list-{{ paragraph.id() }}">
            {% for row in paragraph.field_accordion_items.referencedEntities() %}
            <div class="accordion-item">
                <h2 class="accordion-header accordion-item-headline" id="heading-{{ row.id() }}">
                    <button
                        class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                        data-bs-target="#collapse-{{ row.id() }}" aria-expanded="false"
                        aria-controls="collapse-{{ row.id() }}">
                        {{ row.field_accordion_item_title.value }}
                    </button>
                </h2>
                <div id="collapse-{{ row.id() }}" class="accordion-collapse collapse accordion-item-body"
                    aria-labelledby="heading-{{ row.id() }}" data-bs-parent="#accordion-item-accordion-list-{{ paragraph.id() }}">
                    <div class="accordion-body">
                        {{ row.field_accordion_item_detail.value|raw }}
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
      {% endif %}
      {# Full width - one column layout end #}

      {# Two-Column layout start #}
      {% if paragraph.field_accordion_section_layout.value == 2 %}
          {% set items_count = 0 + paragraph.field_accordion_items.referencedEntities()|length %}
          {% set items_in_left = (items_count / 2)|round(0, 'ceil') %}
          {% set items_in_right = (items_count / 2)|round(0, 'floor') %}
          <div class="accordion accordion-items-list" id="accordion-item-accordion-list-{{ paragraph.id() }}">
            <div class="row">
                <div class="col-12 col-xs-12 col-sm-12 col-md-6 col-lg-6 col-xl-6 col-xxl-6">
                    {% for row in paragraph.field_accordion_items.referencedEntities() %}
                      {% if loop.index <= items_in_left %}
                      <div class="accordion-item">
                          <h2 class="accordion-header accordion-item-headline" id="heading-{{ row.id() }}">
                              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                  data-bs-target="#collapse-{{ row.id() }}" aria-expanded="false"
                                  aria-controls="collapse-{{ row.id() }}">
                                  {{ row.field_accordion_item_title.value }}
                              </button>
                          </h2>
                          <div id="collapse-{{ row.id() }}" class="accordion-collapse collapse accordion-item-body"
                              aria-labelledby="heading-{{ row.id() }}" data-bs-parent="#accordion-item-accordion-list-{{ paragraph.id() }}">
                              <div class="accordion-body">
                                  {{ row.field_accordion_item_detail.value|raw }}
                              </div>
                          </div>
                      </div>
                      {% endif %}
                    {% endfor %}
                </div>{# col-6 col-sm-12 #}
                <div class="col-12 col-xs-12 col-sm-12 col-md-6 col-lg-6 col-xl-6 col-xxl-6">
                    {% for row in paragraph.field_accordion_items.referencedEntities() %}
                      {% if loop.index > items_in_left and loop.index <= items_count %}
                      <div class="accordion-item">
                          <h2 class="accordion-header accordion-item-headline" id="heading-{{ row.id() }}">
                              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                  data-bs-target="#collapse-{{ row.id() }}" aria-expanded="false"
                                  aria-controls="collapse-{{ row.id() }}">
                                  {{ row.field_accordion_item_title.value }}
                              </button>
                          </h2>
                          <div id="collapse-{{ row.id() }}" class="accordion-collapse collapse accordion-item-body"
                              aria-labelledby="heading-{{ row.id() }}" data-bs-parent="#accordion-item-accordion-list-{{ paragraph.id() }}">
                              <div class="accordion-body">
                                  {{ row.field_accordion_item_detail.value|raw }}
                              </div>
                          </div>
                      </div>
                      {% endif %}
                    {% endfor %}
                </div>{# col-6 col-sm-12 #}
            </div>{# row #}

        </div>{# accordion-list #}
      {% endif %}
      {# Two-Column layout end #}
    </div>
  </div>

{% endblock paragraph %}
