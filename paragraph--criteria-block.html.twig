{#
/**
 * @file
 * Default theme implementation to display a paragraph.
 *
 * Available variables:
 * - paragraph: Full paragraph entity.
 *   Only method names starting with "get", "has", or "is" and a few common
 *   methods such as "id", "label", and "bundle" are available. For example:
 *   - paragraph.getCreatedTime() will return the paragraph creation timestamp.
 *   - paragraph.id(): The paragraph ID.
 *   - paragraph.bundle(): The type of the paragraph, for example, "image" or "text".
 *   - paragraph.getOwnerId(): The user ID of the paragraph author.
 *   See Drupal\paragraphs\Entity\Paragraph for a full list of public properties
 *   and methods for the paragraph object.
 * - content: All paragraph items. Use {{ content }} to print them all,
 *   or print a subset such as {{ content.field_example }}. Use
 *   {{ content|without('field_example') }} to temporarily suppress the printing
 *   of a given child element.
 * - attributes: HTML attributes for the containing element.
 *   The attributes.class element may contain one or more of the following
 *   classes:
 *   - paragraphs: The current template type (also known as a "theming hook").
 *   - paragraphs--type-[type]: The current paragraphs type. For example, if the paragraph is an
 *     "Image" it would result in "paragraphs--type--image". Note that the machine
 *     name will often be in a short form of the human readable label.
 *   - paragraphs--view-mode--[view_mode]: The View Mode of the paragraph; for example, a
 *     preview would result in: "paragraphs--view-mode--preview", and
 *     default: "paragraphs--view-mode--default".
 * - view_mode: View mode; for example, "preview" or "full".
 * - logged_in: Flag for authenticated user status. Will be true when the
 *   current user is a logged-in member.
 * - is_admin: Flag for admin user status. Will be true when the current user
 *   is an administrator.
 *
 * @see template_preprocess_paragraph()
 *
 * @ingroup themeable
 */
#}
{% if paragraph.field_criteria_color_style.value == 1 %}
  {% set criterial_color_style = 'criteria-style-transparent' %}
{% elseif paragraph.field_criteria_color_style.value == 2 %}
  {% set criterial_color_style = 'criteria-style-blue' %}
{% elseif paragraph.field_criteria_color_style.value == 3 %}
  {% set criterial_color_style = 'criteria-style-gray' %}
{% elseif paragraph.field_criteria_color_style.value == 4 %}
  {% set criterial_color_style = 'criteria-style-white' %}
{% endif %}
{%
  set classes = [
    'paragraph',
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
    not paragraph.isPublished() ? 'paragraph--unpublished',
    criterial_color_style
  ]
%}
{# anchor start #}
{% if paragraph.field_anchor_position is empty %}
  {% set anchor_pos = 1 %}
{% else %}
  {% set anchor_pos = paragraph.field_anchor_position %}
{% endif %}
{# anchor end #}
{% block paragraph %}
  {% if paragraph.field_criteria_background_image.isEmpty() != true %}
  <div style="background-image: url({{ file_url(paragraph.field_criteria_background_image.entity.field_media_image.entity.uri.value | image_style('criteria')) }});
    background-repeat: no-repeat;background-position: center center; background-size: cover;" class="{{ classes|join(' ') }}" data-type-anchor="anchor-position--criteria-block-{{ anchor_pos }}">
    <div id="anchor-position--criteria-block-{{ anchor_pos }}"></div>
  {% else %}
  <div{{ attributes.addClass(classes) }} data-type-anchor=="anchor-position--criteria-block-{{ anchor_pos }}">
    <div id="anchor-position--criteria-block-{{ anchor_pos }}"></div>
  {% endif %}
    <div class="criteria-block-wrapper">
      {% if paragraph.field_criteria_sign_image.isEmpty() != true %}
      <div class="criteria-media-wrapper">
          <img class="lazyload criteria-sign" src="{{ file_url(paragraph.field_criteria_sign_image.entity.field_media_image.entity.uri.value | image_style('criteria_sign')) }}"
               alt="{{ paragraph.field_criteria_sign_image.entity.field_media_image.alt }}" />
      </div>
      {% endif %}

      {% if paragraph.field_criteria_headline.value is not empty %}
        <h3 class="criteria-headline">{{ paragraph.field_criteria_headline.value }}</h3>
      {% endif %}
      {% if paragraph.field_criteria_sub_headline.value is not empty %}
        <h4 class="criteria-sub-headline">{{ paragraph.field_criteria_sub_headline.value }}</h4>
      {% endif %}
      {% if paragraph.field_criteria_detail.value is not empty %}
        <div class="criteria-detail">{{ paragraph.field_criteria_detail.value|raw }}</div>
      {% endif %}
      {% if paragraph.field_criteria_cta_link.title is not empty %}
        <div class="criteria-actions">
          {% set cta_url = paragraph.field_criteria_cta_link.0.url.toString() is empty ? '#' : paragraph.field_criteria_cta_link.0.url  %}
          <a class="criteria-link" href="{{ cta_url }}" alt="{{ 'CTA'|t }}">
            {{ paragraph.field_criteria_cta_link.title }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
{% endblock paragraph %}
