{#
/**
 * @file
 * Default theme implementation to display a paragraph.
 *
 * Available variables:
 * - paragraph: Full paragraph entity.
 *   Only method names starting with "get", "has", or "is" and a few common
 *   methods such as "id", "label", and "bundle" are available. For example:
 *   - paragraph.getCreatedTime() will return the paragraph creation timestamp.
 *   - paragraph.id(): The paragraph ID.
 *   - paragraph.bundle(): The type of the paragraph, for example, "image" or "text".
 *   - paragraph.getOwnerId(): The user ID of the paragraph author.
 *   See Drupal\paragraphs\Entity\Paragraph for a full list of public properties
 *   and methods for the paragraph object.
 * - content: All paragraph items. Use {{ content }} to print them all,
 *   or print a subset such as {{ content.field_example }}. Use
 *   {{ content|without('field_example') }} to temporarily suppress the printing
 *   of a given child element.
 * - attributes: HTML attributes for the containing element.
 *   The attributes.class element may contain one or more of the following
 *   classes:
 *   - paragraphs: The current template type (also known as a "theming hook").
 *   - paragraphs--type-[type]: The current paragraphs type. For example, if the paragraph is an
 *     "Image" it would result in "paragraphs--type--image". Note that the machine
 *     name will often be in a short form of the human readable label.
 *   - paragraphs--view-mode--[view_mode]: The View Mode of the paragraph; for example, a
 *     preview would result in: "paragraphs--view-mode--preview", and
 *     default: "paragraphs--view-mode--default".
 * - view_mode: View mode; for example, "preview" or "full".
 * - logged_in: Flag for authenticated user status. Will be true when the
 *   current user is a logged-in member.
 * - is_admin: Flag for admin user status. Will be true when the current user
 *   is an administrator.
 *
 * @see template_preprocess_paragraph()
 *
 * @ingroup themeable
 */
#}
{# anchor start #}
{% if paragraph.field_anchor_position is empty %}
  {% set anchor_pos = 1 %}
{% else %}
  {% set anchor_pos = paragraph.field_anchor_position %}
{% endif %}
{# anchor end #}

{% if paragraph.field_hero_button_style.value == 3 %}
  {% set hero_button_style_class = 'hero-button-style-white' %}
{% elseif paragraph.field_hero_button_style.value == 1 %}
  {% set hero_button_style_class = 'hero-button-style-blue' %}
{% else %}
  {% set hero_button_style_class = 'hero-button-style-yellow' %}
{% endif %}

{% if paragraph.field_hero_button_fill_style.value == 2 %}
  {% set hero_button_fill_style_class = 'hero-button-fill-style-transparent' %}
{% else %}
  {% set hero_button_fill_style_class = 'hero-button-fill-style-filled' %}
{% endif %}

{% if paragraph.field_hero_banner_color_style.value == 3 %}
  {% set hero_banner_color_style_class = 'hero-banner-style-white' %}
{% elseif paragraph.field_hero_banner_color_style.value == 2 %}
  {% set hero_banner_color_style_class = 'hero-banner-style-blue' %}
{% else %}
  {% set hero_banner_color_style_class = 'hero-banner-style-gray' %}
{% endif %}

{% block paragraph %}
  {%
    set classes = [
    'paragraph',
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
    not paragraph.isPublished() ? 'paragraph--unpublished',
    hero_button_style_class,
    hero_button_fill_style_class,
    hero_banner_color_style_class,
    paragraph.field_adjust_with_breadcrumbs.value == 1 ? 'hero-adjust-with-breadcrumbs' : '',
  ]
  %}
  <div{{ attributes.addClass(classes) }} data-type-anchor="anchor-position--hero-banner-{{ anchor_pos }}">
    <div id="anchor-position--hero-banner-{{ anchor_pos }}"></div>
    <div class="hero-banner-inner">
      {% if paragraph.field_adjust_with_breadcrumbs.value == 1 %}
        <div class="container breadcrumb-container clearfix">{{ hero_breadcrumb }}</div>
      {% endif %}
      <div class="hero-banner-content">
        <div class="hero-banner-content-inner">
          <div class="hero-banner-bar">&nbsp;</div>
          <{{ paragraph.field_headline_size.value }} class="hero-banner-headline">{{ paragraph.field_hero_headline.value }}</{{ paragraph.field_headline_size.value }}>
          {% if paragraph.field_hero_subheadline.value is not empty %}
            <div class="hero-banner-subheadline">{{ paragraph.field_hero_subheadline.value }}</div>
          {% endif %}
          {% if paragraph.field_hero_text.value is not empty %}
            <div class="hero-banner-text">{{ paragraph.field_hero_text.value|raw }}</div>
          {% endif %}
          {% if paragraph.field_hero_button_1_link.title is not empty or paragraph.field_hero_button_2_link.title is not empty %}
          <div class="hero-banner-link-wrapper">
            {# Check if Banner link 1 is empty. #}
            {% if paragraph.field_hero_button_1_link.title is not empty %}
              {% set link_1_url = paragraph.field_hero_button_1_link.0.url.toString() is empty ? '#' : paragraph.field_hero_button_1_link.0.url  %}
              <a class="hero-banner-link hero-banner-link-1" href="{{ link_1_url }}" alt="{{ 'Banner link'|t }}">
                {{ paragraph.field_hero_button_1_link.title }}
              </a>
            {% endif %}
            {# Check if Banner link 2 is empty. #}
            {% if paragraph.field_hero_button_2_link.title is not empty %}
              {% set link_2_url = paragraph.field_hero_button_2_link.0.url.toString() is empty ? '#' : paragraph.field_hero_button_2_link.0.url  %}
              <a class="hero-banner-link hero-banner-link-2" href="{{ link_2_url }}" alt="{{ 'Banner link'|t }}">
                {{ paragraph.field_hero_button_2_link.title }}
              </a>
            {% endif %}
          </div>
          {% endif %}
        </div>
      </div><!-- hero-banner-content -->

      <div style="background-image: url({{ file_url(paragraph.field_hero_image.entity.field_media_image.entity.uri.value | image_style('hero_image')) }});
        background-repeat: no-repeat;background-position: center; background-size: cover;" class="hero-banner-media">
        <div class="hero-banner-media-spacer">&nbsp;</div>
      </div><!-- hero-banner-media -->

    </div>
    <div class="hero-banner-footer-wrapper">
      <img class="lazyload hero-banner-footer" src="/{{ directory }}/images/banner-bottom.svg" alt="Banner" />
    </div>
    {% if paragraph.field_display_badge.value == 1 %}
      {% if paragraph.field_hero_badge_color.value == 1 %} {# Gray #}
        {% set badge_color_layout = 'badge-color-layout-gray' %}
      {% elseif paragraph.field_hero_badge_color.value == 2 %} {# Blue #}
        {% set badge_color_layout = 'badge-color-layout-blue' %}
      {% elseif paragraph.field_hero_badge_color.value == 3 %} {# White #}
        {% set badge_color_layout = 'badge-color-layout-white' %}
      {% elseif paragraph.field_hero_badge_color.value == 4 %} {# Yellow #}
        {% set badge_color_layout = 'badge-color-layout-yellow' %}
      {% else %}
        {% set badge_color_layout = 'badge-color-layout-yellow' %}
      {% endif %}
      {% if paragraph.field_hero_badge.entity == true %}
        <div class="hero-badge-wrapper">
          <div class="hero-badge-inner {{ badge_color_layout }}">
            {% if paragraph.field_hero_badge.entity.field_badge_text.value is not empty %}
              <div class="badge-text">{{ paragraph.field_hero_badge.entity.field_badge_text.value|raw }}</div>
            {% endif %}
            {% if (paragraph.field_hero_badge.entity.field_badge_text.value is not empty and
              paragraph.field_hero_badge.entity.field_badge_cta_text.value is not empty) %}
              <div class="badge-divider"></div>
            {% endif %}
            {% if paragraph.field_hero_badge.entity.field_badge_cta_text.value is not empty %}
              <div class="badge-cta-text">{{ paragraph.field_hero_badge.entity.field_badge_cta_text.value|raw }}</div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endif %}

  </div>

{% endblock paragraph %}
