{#
/**
 * @file
 * Default theme implementation to display a paragraph.
 *
 * Available variables:
 * - paragraph: Full paragraph entity.
 *   Only method names starting with "get", "has", or "is" and a few common
 *   methods such as "id", "label", and "bundle" are available. For example:
 *   - paragraph.getCreatedTime() will return the paragraph creation timestamp.
 *   - paragraph.id(): The paragraph ID.
 *   - paragraph.bundle(): The type of the paragraph, for example, "image" or "text".
 *   - paragraph.getOwnerId(): The user ID of the paragraph author.
 *   See Drupal\paragraphs\Entity\Paragraph for a full list of public properties
 *   and methods for the paragraph object.
 * - content: All paragraph items. Use {{ content }} to print them all,
 *   or print a subset such as {{ content.field_example }}. Use
 *   {{ content|without('field_example') }} to temporarily suppress the printing
 *   of a given child element.
 * - attributes: HTML attributes for the containing element.
 *   The attributes.class element may contain one or more of the following
 *   classes:
 *   - paragraphs: The current template type (also known as a "theming hook").
 *   - paragraphs--type-[type]: The current paragraphs type. For example, if the paragraph is an
 *     "Image" it would result in "paragraphs--type--image". Note that the machine
 *     name will often be in a short form of the human readable label.
 *   - paragraphs--view-mode--[view_mode]: The View Mode of the paragraph; for example, a
 *     preview would result in: "paragraphs--view-mode--preview", and
 *     default: "paragraphs--view-mode--default".
 * - view_mode: View mode; for example, "preview" or "full".
 * - logged_in: Flag for authenticated user status. Will be true when the
 *   current user is a logged-in member.
 * - is_admin: Flag for admin user status. Will be true when the current user
 *   is an administrator.
 *
 * @see template_preprocess_paragraph()
 *
 * @ingroup themeable
 */
#}
{%
  set classes = [
    'paragraph',
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
    not paragraph.isPublished() ? 'paragraph--unpublished'
  ]
%}
{% if paragraph.field_infobox_type.value == 1 %}
  {% set infobox_class = 'infobox-type-normal' %}
{% else %}
  {% set infobox_class = 'infobox-type-sponsored' %}
{% endif %}

{% block paragraph %}
  <div{{ attributes.addClass(classes, infobox_class) }}>
    <div class="container clearfix">
      {% if paragraph.field_infobox_type.value == 1 %} {# Normal #}
        <div class="infobox-inner-content">
          {% if paragraph.field_infobox_headline.value is not empty %}
            <h3 class="infobox-title">{{ paragraph.field_infobox_headline.value }}</h3>
          {% endif %}
          {% if paragraph.field_infobox_content.value is not empty %}
            <div class="infobox-content">{{ paragraph.field_infobox_content.value|raw }}</div>
          {% endif %}
          {% if paragraph.field_infobox_embeded_code.value is not empty %}
            <div class="infobox-embedcode">{{ paragraph.field_infobox_embeded_code.value|raw }}</div>
          {% endif %}
          {% if paragraph.field_infobox_more_link.title is not empty %}
            {% set link_url = paragraph.field_infobox_more_link.0.url.toString() is empty ? '#' :
              paragraph.field_infobox_more_link.0.url  %}
            <div class="infobox-more-link">
              <a class="info-more-link" href="{{ link_url }}">{{ paragraph.field_infobox_more_link.title }}</a>
            </div>
          {% endif %}
        </div>
      {% else %}  {# Sponsored #}
        {% set infocontent = 'info-content-empty' %}
        {% if paragraph.field_infobox_content.value %}
          {% set infocontent = '' %}
        {% endif %}
        <div class="infobox-inner-content {{ infocontent }}">
          <div class="sponsor-info-wrapper">
          {% if paragraph.field_sponsor_type.value == 1 %} {# Advertiser #}
            {% if paragraph.field_advertiser.isEmpty() != true %}{{ drupal_entity('node', paragraph.field_advertiser.entity.id, 'teaser') }}{% endif %}
          {% else %} {# Sponsor #}
            {% if paragraph.field_sponsor.isEmpty() != true %}{{ drupal_entity('node', paragraph.field_sponsor.entity.id, 'teaser') }}{% endif %}
          {% endif %}
          </div>
          {% if paragraph.field_infobox_content.value is empty %}
            <div class="info-title-and-cta">
          {% endif %}
          {% if paragraph.field_infobox_headline.value is not empty %}
            <h3 class="infobox-title">{{ paragraph.field_infobox_headline.value }}</h3>
          {% endif %}
          {% if paragraph.field_infobox_content.value is not empty %}
            <div class="infobox-content">{{ paragraph.field_infobox_content.value|raw }}</div>
          {% endif %}
          {% if paragraph.field_infobox_embeded_code.value is not empty %}
            <div class="infobox-embedcode">{{ paragraph.field_infobox_embeded_code.value|raw }}</div>
          {% endif %}

          {% if paragraph.field_sponsor_cta.title is not empty %}
            {% set link_url = paragraph.field_sponsor_cta.0.url.toString() is empty ? '#' :
              paragraph.field_sponsor_cta.0.url  %}
            <div class="infobox-cta-link-wrapper">
              <a class="info-cta-link" href="{{ link_url }}">{{ paragraph.field_sponsor_cta.title }}</a>
            </div>
          {% endif %}
          {% if paragraph.field_infobox_content.value is empty %}
            </div>
          {% endif %}
          {% if paragraph.field_infobox_more_link.title is not empty %}
            {% set link_url = paragraph.field_infobox_more_link.0.url.toString() is empty ? '#' :
              paragraph.field_infobox_more_link.0.url  %}
            <div class="infobox-more-link-wrapper">
              <a class="info-more-link" href="{{ link_url }}">{{ paragraph.field_infobox_more_link.title }}</a>
            </div>
          {% endif %}
        </div>
      {% endif %}

    </div>
  </div>
{% endblock paragraph %}
