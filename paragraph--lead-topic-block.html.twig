{#
/**
 * @file
 * Default theme implementation to display a paragraph.
 *
 * Available variables:
 * - paragraph: Full paragraph entity.
 *   Only method names starting with "get", "has", or "is" and a few common
 *   methods such as "id", "label", and "bundle" are available. For example:
 *   - paragraph.getCreatedTime() will return the paragraph creation timestamp.
 *   - paragraph.id(): The paragraph ID.
 *   - paragraph.bundle(): The type of the paragraph, for example, "image" or "text".
 *   - paragraph.getOwnerId(): The user ID of the paragraph author.
 *   See Drupal\paragraphs\Entity\Paragraph for a full list of public properties
 *   and methods for the paragraph object.
 * - content: All paragraph items. Use {{ content }} to print them all,
 *   or print a subset such as {{ content.field_example }}. Use
 *   {{ content|without('field_example') }} to temporarily suppress the printing
 *   of a given child element.
 * - attributes: HTML attributes for the containing element.
 *   The attributes.class element may contain one or more of the following
 *   classes:
 *   - paragraphs: The current template type (also known as a "theming hook").
 *   - paragraphs--type-[type]: The current paragraphs type. For example, if the paragraph is an
 *     "Image" it would result in "paragraphs--type--image". Note that the machine
 *     name will often be in a short form of the human readable label.
 *   - paragraphs--view-mode--[view_mode]: The View Mode of the paragraph; for example, a
 *     preview would result in: "paragraphs--view-mode--preview", and
 *     default: "paragraphs--view-mode--default".
 * - view_mode: View mode; for example, "preview" or "full".
 * - logged_in: Flag for authenticated user status. Will be true when the
 *   current user is a logged-in member.
 * - is_admin: Flag for admin user status. Will be true when the current user
 *   is an administrator.
 *
 * @see template_preprocess_paragraph()
 *
 * @ingroup themeable
 */
#}
{%
  set classes = [
  'paragraph',
  'paragraph--type--' ~ paragraph.bundle|clean_class,
  view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
  not paragraph.isPublished() ? 'paragraph--unpublished'
]
%}
{% if paragraph.field_color_layout.value == 1 %}
  {% set layout_color_style_class = 'layout-color-style-gray' %}
{% elseif paragraph.field_color_layout.value == 3 %}
  {% set layout_color_style_class = 'layout-color-style-darkgray' %}
{% else %}
  {% set layout_color_style_class = 'layout-color-style-white' %}
{% endif %}

{% if paragraph.field_lead_block_style.value == 1 %}
  {% set teaser_style_class = 'teaser-style-hero-only' %}
{% elseif paragraph.field_lead_block_style.value == 2 %}
  {% set teaser_style_class = 'teaser-style-hero-and-one-teaser' %}
{% elseif paragraph.field_lead_block_style.value == 3 %}
  {% set teaser_style_class = 'teaser-style-hero-and-two-teaser' %}
{% elseif paragraph.field_lead_block_style.value == 4 %}
  {% set teaser_style_class = 'teaser-style-hero-and-three-teaser' %}
{% else %}
  {% set teaser_style_class = 'teaser-style-hero-and-three-teaser' %}
{% endif %}

{% block paragraph %}
  <div{{ attributes.addClass(classes, layout_color_style_class, teaser_style_class) }}>
    <div class="container clearfix">
      <div class="lead-section-wrapper">
        <div class="lead-top-section-left">
          {% if topic_breadcrumb is not empty %}
            <div class="topic-breadcrumb">{{ topic_breadcrumb }}</div>
          {% endif %}
          {% if paragraph.field_section_title.value is not empty %}
            <h3 class="section-title">{{ paragraph.field_section_title.value }}</h3>
          {% endif %}
          {% if hero_node == true %}
            <div class="hero-last-updated">
              Aktualisiert {{ story_time_ago(hero_node, 2, 2) }}
            </div>
          {% endif %}

          {% if paragraph.field_section_link.title is not empty %}
            {% set section_link_url = paragraph.field_section_link.0.url.toString() is empty ? '#' :
              paragraph.field_section_link.0.url  %}
            <a class="topic-block-link" href="{{ section_link_url }}">
              {{ paragraph.field_section_link.title }}
            </a>
          {% endif %}
        </div>
        <div class="lead-top-section-right">
          {% if hero_node == true %}
          <div class="lead-top-section">
            <div class="hero-teaser">{{ drupal_entity('node', hero_node.id, 'hero_horizontal') }}</div>
          </div>
          {% endif %}

          {% if nodes|length > 0 %}
            <div class="lead-bottom-section">
              {# Render the nodes for middle section #}
              {% if nodes is not empty %}
                {% for bottom_node in nodes %}
                  <div class="simple-teaser">{{ drupal_entity('node', bottom_node.id, 'teaser_simple_1') }}</div>
                {% endfor %}
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
{% endblock paragraph %}
