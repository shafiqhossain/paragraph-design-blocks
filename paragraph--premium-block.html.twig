{#
/**
 * @file
 * Default theme implementation to display a paragraph.
 *
 * Available variables:
 * - paragraph: Full paragraph entity.
 *   Only method names starting with "get", "has", or "is" and a few common
 *   methods such as "id", "label", and "bundle" are available. For example:
 *   - paragraph.getCreatedTime() will return the paragraph creation timestamp.
 *   - paragraph.id(): The paragraph ID.
 *   - paragraph.bundle(): The type of the paragraph, for example, "image" or "text".
 *   - paragraph.getOwnerId(): The user ID of the paragraph author.
 *   See Drupal\paragraphs\Entity\Paragraph for a full list of public properties
 *   and methods for the paragraph object.
 * - content: All paragraph items. Use {{ content }} to print them all,
 *   or print a subset such as {{ content.field_example }}. Use
 *   {{ content|without('field_example') }} to temporarily suppress the printing
 *   of a given child element.
 * - attributes: HTML attributes for the containing element.
 *   The attributes.class element may contain one or more of the following
 *   classes:
 *   - paragraphs: The current template type (also known as a "theming hook").
 *   - paragraphs--type-[type]: The current paragraphs type. For example, if the paragraph is an
 *     "Image" it would result in "paragraphs--type--image". Note that the machine
 *     name will often be in a short form of the human readable label.
 *   - paragraphs--view-mode--[view_mode]: The View Mode of the paragraph; for example, a
 *     preview would result in: "paragraphs--view-mode--preview", and
 *     default: "paragraphs--view-mode--default".
 * - view_mode: View mode; for example, "preview" or "full".
 * - logged_in: Flag for authenticated user status. Will be true when the
 *   current user is a logged-in member.
 * - is_admin: Flag for admin user status. Will be true when the current user
 *   is an administrator.
 *
 * @see template_preprocess_paragraph()
 *
 * @ingroup themeable
 */
#}
{%
  set classes = [
    'paragraph',
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
    not paragraph.isPublished() ? 'paragraph--unpublished'
  ]
%}
{% if paragraph.field_color_layout.value == 1 %}
  {% set layout_color_style_class = 'layout-color-style-gray' %}
{% elseif paragraph.field_color_layout.value == 2 %}
  {% set layout_color_style_class = 'layout-color-style-white' %}
{% else %}
  {% set layout_color_style_class = 'layout-color-style-dark-gray' %}
{% endif %}

{% block paragraph %}
  <div{{ attributes.addClass(classes, layout_color_style_class) }}>
    <div class="container clearfix">
      <div class="premium-section-wrapper">
        <div class="section-left">
          <div class="section-left-top">
            <div class="section-left-top-left">
              {% if paragraph.field_section_title.value is not empty %}
                <h3 class="section-title">{{ paragraph.field_section_title.value }}</h3>
              {% endif %}
              {% if paragraph.field_sub_title.value is not empty %}
                <h4 class="sub-title">{{ paragraph.field_sub_title.value }}</h4>
              {% endif %}
            </div>
            {% if paragraph.field_section_link.title is not empty %}
              {% set section_link_url = paragraph.field_section_link.0.url.toString() is empty ? '#' :
                paragraph.field_section_link.0.url  %}
              <a class="topic-block-link" href="{{ section_link_url }}">
                {{ paragraph.field_section_link.title }}
              </a>
            {% endif %}
          </div>
          <div class="section-left-bottom">
            <aside class="subscription-teaser">
              <div class="subscription-teaser__headings">
                <span class="premium-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="17" viewBox="0 0 28 17">
    <g fill="#FFF" fill-rule="nonzero">
        <path d="M1.48 8.5c.007-3.635 2.74-6.664 6.3-6.983V.027C3.404.331.007 4.026 0 8.486c-.007 4.461 3.38 8.167 7.754 8.487v-1.49C4.199 15.16 1.476 12.13 1.479 8.5z"/>
        <path d="M6.905 10.88c-.31.218-.677.336-1.054.34-1.312 0-1.98-1.255-1.98-2.825 0-1.909.848-2.641 1.903-2.641.393.005.776.123 1.106.34l.205.941h.592c.082-.598.125-1.2.128-1.804H7.42l-.18.314a2.834 2.834 0 0 0-1.363-.288c-2.058 0-3.266 1.465-3.266 3.295 0 1.753 1.106 3.191 3.163 3.191a5.094 5.094 0 0 0 2.031-.47c.026-.288.052-.68.052-1.335h-.669l-.283.942zM8.551 11.298l.103.314h4.86c.083-.571.126-1.148.129-1.726H13l-.309 1.177-2.571.052.823-1.229 2.597-4.184-.103-.393H8.783c.002.578.045 1.155.128 1.726h.566l.206-1.177 2.34-.052-.823 1.23-2.649 4.262z"/>
        <path d="M19.668.026h-4.264L8.68 0v1.49c3.702.153 6.625 3.254 6.618 7.023-.007 3.768-2.94 6.858-6.644 6.996V17l6.75-.026h4.264c4.601-.002 8.33-3.795 8.332-8.474-.001-4.68-3.73-8.472-8.332-8.474zm4.868 9.154H21.82v2.955h-1.604V9.19H17.5V7.668h2.716V4.776h1.604v2.892h2.716V9.18z"/>
    </g>
</svg></span><span>Premium Abo</span>
              </div>

              <div class="subscription-image"><svg xmlns="http://www.w3.org/2000/svg" width="81" height="36" viewBox="0 0 81 36">
    <g fill="#FFF" fill-rule="evenodd">
        <path d="M39.6 36H.9c-.54 0-.9-.36-.9-.9s.36-.9.9-.9h38.7c.54 0 .9.36.9.9s-.36.9-.9.9M36.9 9H3.6c-.54 0-.9.36-.9.9v22.5c0 .54.36.9.9.9h33.3c.54 0 .9-.36.9-.9V9.9c0-.54-.36-.9-.9-.9zM4.5 31.5H36V10.8H4.5v20.7zM68.76 13.5H53.01c-.45 0-.81.36-.81.72v21.06c0 .36.36.72.81.72h15.48c.45 0 .81-.36.81-.72V14.04c0-.36-.27-.54-.54-.54zM54 34.2h13.5V15.3H54v18.9zM80.1 18h-9c-.54 0-.9.36-.9.9v16.2c0 .54.36.9.9.9h9c.54 0 .9-.36.9-.9V18.9c0-.54-.36-.9-.9-.9zM72 34.2h7.2V19.8H72v14.4z"/>
        <path d="M65.7 1.8c0-.99-.81-1.8-1.8-1.8H28.8c-.99 0-1.8.81-1.8 1.8v6.3h1.8V1.8h35.1v10.8h1.8V1.8zM51.3 28.8V27H38.7v1.8H45v5.4h-3.6V36h9.9v-1.8h-4.5v-5.4z"/>
    </g>
</svg></div>

              <div class="subscription-teaser__content">
                <ul class="check-list check-list--premium">
                  <li><div class="rectangle"></div>1. Monat für 0,99 €</li>
                  <li><div class="rectangle"></div>alle Premium Artikel</li>
                  <li><div class="rectangle"></div>monatlich online kündbar</li>
                </ul>
              </div>

              <a class="button button--hollow" href="#">jetzt testen</a>
            </aside>
          </div>
        </div>
        <div class="section-middle">
          {% if nodes is not empty %}
            {% set first_node = nodes|first %}
            {% if first_node is not empty %}
              <div class="premium-top-wrapper">
              {{ drupal_entity('node', first_node.id, 'hero_full_2') }}
              </div>
            {% endif %}

            {% set second_node = null %}
            {% set third_node = null %}
            {% for bottom_node in nodes[1:1] %}
              {% set second_node = bottom_node %}
            {% endfor %}
            {% for bottom_node in nodes[2:1] %}
              {% set third_node = bottom_node %}
            {% endfor %}

            {% if second_node is not empty or third_node is not empty %}
              <div class="premium-bottom-wrapper">
            {% endif %}

            {% if second_node is not empty %}
              <div class="premium-bottom-left-wrapper">
                {{ drupal_entity('node', second_node.id, 'hero_full_2') }}
              </div>
            {% endif %}
            {% if third_node is not empty %}
              <div class="premium-bottom-right-wrapper">
                {{ drupal_entity('node', third_node.id, 'hero_full_2') }}
              </div>
            {% endif %}

            {% if second_node is not empty or third_node is not empty %}
              </div>
            {% endif %}

          {% endif %}
        </div>
      </div>
    </div>
  </div>
{% endblock paragraph %}
